{
  "name": "@applitools/req",
  "version": "1.11.1",
  "description": "Applitools fetch-based request library",
  "keywords": [
    "applitools",
    "fetch",
    "request",
    "proxy"
  ],
  "homepage": "https://applitools.com",
  "bugs": {
    "url": "https://github.com/applitools/eyes.sdk.javascript1/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/applitools/eyes.sdk.javascript1.git",
    "directory": "js/packages/req"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "Applitools Team",
    "email": "team@applitools.com"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./types/index.d.ts",
        "browser": "./dist/index.js",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./types/index.d.cts",
        "browser": "./dist/index.js",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "types": "./types/index.d.cts",
  "main": "./dist/index.cjs",
  "browser": {
    ".": "./dist/index.js",
    "./dist/agent.js": "./dist/agent-browser.js",
    "./dist/fetch-http2.js": "./dist/fetch-browser.js",
    "./dist/fetch.js": "./dist/fetch-browser.js"
  },
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "lint": "run --top-level eslint '**/*.ts'",
    "build": "yarn build:ts && yarn build:cjs",
    "build:ts": "run --top-level tspc --project ./tsconfig.build.json",
    "build:cjs": "node ./scripts/bundle.mjs && cp ./types/index.d.ts ./types/index.d.cts",
    "test": "MOCHA_OMIT_TAGS=http2 run --top-level mocha './test/**/*.spec.ts'",
    "test:http2": "APPLITOOLS_HTTP_VERSION=2 MOCHA_OMIT_TAGS=http1 run --top-level mocha './test/**/*.spec.ts'"
  },
  "dependencies": {
    "@applitools/logger": "2.2.13",
    "@applitools/utils": "1.15.0",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.6"
  },
  "devDependencies": {
    "@applitools/api-extractor": "^1.2.22",
    "@applitools/test-server": "^1.4.5",
    "@applitools/test-utils": "^1.5.17",
    "@types/node": "^12.20.55",
    "esbuild": "^0.17.18",
    "node-fetch": "3.3.1",
    "hostile": "^1.3.3",
    "nock": "^13.3.2"
  },
  "engines": {
    "node": ">=16.13.0"
  },
  "optionalDependencies": {
    "undici": ">=6.23.0 <8.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "lavamoat": {
    "allowScripts": {
      "esbuild": false
    }
  }
}