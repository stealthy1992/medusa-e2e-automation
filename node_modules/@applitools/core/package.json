{
  "name": "@applitools/core",
  "version": "4.65.2",
  "homepage": "https://applitools.com",
  "bugs": {
    "url": "https://github.com/applitools/eyes.sdk.javascript1/issues"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/applitools/eyes.sdk.javascript1.git",
    "directory": "js/packages/core-base"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": {
    "name": "Applitools Team",
    "email": "team@applitools.com"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./offline": {
      "types": "./types/offline.d.ts",
      "default": "./dist/offline.js"
    },
    "./types": {
      "types": "./types/types.d.ts",
      "default": "./dist/types.js"
    },
    "./dist/*": "./dist/*.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "eyes-check-network": "./dist/troubleshoot/check-network.js"
  },
  "main": "./dist/index.js",
  "types": "./types/index.d.ts",
  "browser": {
    "@applitools/ec-client": false
  },
  "files": [
    "dist",
    "types"
  ],
  "scripts": {
    "lint": "run --top-level eslint '**/*.ts'",
    "build": "yarn build:dist",
    "build:dist": "run --top-level tsc --project ./tsconfig.build.json",
    "test": "run --top-level mocha './test/**/*.spec.ts' --exclude 'test/e2e/mocha-sync/**' --parallel --jobs ${MOCHA_JOBS:-15} --exit --require ./test/mocha-global-setup.js",
    "test:local": "MOCHA_OMIT_TAGS=sauce,browserstack run test",
    "test:sauce": "MOCHA_ONLY_TAGS=sauce,browserstack run test",
    "test:bin": "MOCHA_GROUP=bin run --top-level mocha './test/bin/**/*.spec.ts' --parallel --jobs ${MOCHA_JOBS:-15} --require ./test/mocha-global-setup.js",
    "test:e2e": "MOCHA_OMIT_TAGS=http2 MOCHA_GROUP=e2e run --top-level mocha './test/e2e/**/*.spec.ts' --exclude 'test/e2e/mocha-sync/**' --parallel --jobs ${MOCHA_JOBS:-15} --exit --require ./test/mocha-global-setup.js",
    "test:e2e:http2": "APPLITOOLS_HTTP_VERSION=2 MOCHA_OMIT_TAGS=http1,sauce,browserstack MOCHA_GROUP=e2e run --top-level mocha './test/e2e/**/*.spec.ts' --exclude 'test/e2e/mocha-sync/**' --parallel --jobs ${MOCHA_JOBS:-15} --exit --require ./test/mocha-global-setup.js",
    "test:it": "MOCHA_GROUP=it run --top-level mocha './test/it/**/*.spec.ts' --require ./test/mocha-global-setup.js",
    "test:e2e:sync": "MOCHA_GROUP=e2e SYNC=true run --top-level mocha './test/e2e/mocha-sync/**/*.spec.ts' --exit --require ./test/mocha-global-setup.js",
    "test:unit": "MOCHA_GROUP=unit run --top-level mocha './test/unit/**/*.spec.ts' --require ./test/mocha-global-setup.js",
    "setup": "run --top-level browsers:setup && run --top-level xvfb:setup && run playwright:setup",
    "playwright:setup": "node -e \"var v=parseInt(process.version.slice(1));if(v>=18){require('child_process').execSync('yarn playwright install --with-deps firefox',{stdio:'inherit'})}else{console.log('Skipping playwright install (Node '+process.version+')')}\"",
    "setup:standalone": "sh -c 'yarn chromedriver --port=4444 --verbose &'"
  },
  "dependencies": {
    "@applitools/core-base": "1.35.3",
    "@applitools/dom-capture": "11.8.2",
    "@applitools/dom-snapshot": "4.17.4",
    "@applitools/driver": "1.26.4",
    "@applitools/ec-client": "1.12.35",
    "@applitools/logger": "2.2.13",
    "@applitools/nml-client": "1.11.33",
    "@applitools/req": "1.11.1",
    "@applitools/screenshoter": "3.12.23",
    "@applitools/snippets": "2.9.3",
    "@applitools/socket": "1.3.14",
    "@applitools/ufg-client": "1.22.4",
    "@applitools/utils": "1.15.0",
    "abort-controller": "3.0.0",
    "chalk": "4.1.2",
    "node-fetch": "2.6.7",
    "semver": "7.6.2",
    "throat": "6.0.2"
  },
  "devDependencies": {
    "@applitools/bongo": "^5.10.0",
    "@applitools/spec-driver-playwright": "^1.9.4",
    "@applitools/spec-driver-puppeteer": "^1.8.4",
    "@applitools/spec-driver-selenium": "^1.8.4",
    "@applitools/spec-driver-webdriver": "^1.6.4",
    "@applitools/test-server": "^1.4.5",
    "@applitools/test-utils": "^1.5.17",
    "@applitools/tunnel-client": "^1.12.1",
    "@swc-node/register": "^1.6.8",
    "@types/mocha": "^10.0.7",
    "@types/node": "^12.20.55",
    "@types/selenium-webdriver": "^4.1.2",
    "@types/semver": "^7.5.8",
    "chai": "^4.2.0",
    "chromedriver": "^131.0.5",
    "crypto": "^1.0.1",
    "express": "^4.10.6",
    "mocha": "^11.7.5",
    "nock": "^13.3.2",
    "playwright": "1.47.0",
    "png-async": "^0.9.4",
    "puppeteer": "^24.11.1",
    "selenium-webdriver": "^4.15.0",
    "webdriver": "^5.23.0"
  },
  "engines": {
    "node": ">=12.13.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "lavamoat": {
    "allowScripts": {
      "chromedriver": true,
      "puppeteer": true,
      "ws>bufferutil": false,
      "ws>utf-8-validate": false,
      "@applitools/core-base>@applitools/image>sharp": false,
      "@swc-node/register>@swc/core": false,
      "selenium-webdriver>ws>bufferutil": false,
      "selenium-webdriver>ws>utf-8-validate": false
    }
  }
}