          "$.body.products[*].variants[*].prices[*].amount": { "match": "type" },
          "$.body.products[*].variants[*].prices[*].currency_code": { "match": "type" },
          "$.body.count": { "match": "type" },
          "$.body.offset": { "match": "type" },
          "$.body.limit": { "match": "type" }
